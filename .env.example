# LLM Provider: mock, openrouter
LLM_PROVIDER=mock

# OpenRouter (required when LLM_PROVIDER=openrouter)
# OPENROUTER_API_KEY=your_api_key_here
# OPENROUTER_MODEL=openrouter/free

# App URL (used for OpenRouter referer header)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Log level: debug, info, error (default: info)
LOG_LEVEL=info

# Raw transcript logging — when enabled, writes the FULL untruncated system
# prompt, user message, and raw model response for every model call to disk
# (one file per run). Off by default. Useful for debugging / auditing.
# COUNCIL_RAW_LOG=true
# COUNCIL_RAW_LOG_DIR=./logs/council
# COUNCIL_RAW_LOG_FORMAT=jsonl   # jsonl (default) or text

# Retry & timeout configuration
# LLM_MAX_RETRIES=3
# LLM_RETRY_BASE_DELAY=1000
# LLM_REQUEST_TIMEOUT=60000

# Auth (required for login/session)
# Generate a secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=your_random_secret_here

# Storage provider: local (JSON files) or supabase (PostgreSQL)
DB_PROVIDER=local

# Supabase (required when DB_PROVIDER=supabase)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
