{
  "name": "multi-agent-llm-council",
  "description": "A multi-agent council framework for LLMs, built with Next.js and Supabase.",
  "version": "0.1.4",
  "author": "Freudenberger",
  "repository": {
    "type": "git",
    "url": "https://github.com/Freudenberger/multi-agent-llm-council.git"
  },
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "bs": "next build && next start",
    "council": "tsx src/cli/index.ts",
    "review": "tsx tools/ai-review/v1/cli.ts",
    "review:v2": "tsx tools/ai-review/v2/cli.ts",
    "review:v3": "tsx tools/ai-review/v3/cli.ts",
    "review:eval": "promptfoo eval -c tools/ai-review/promptfooconfig.yaml",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm --prefix tests/e2e run test",
    "test:e2e:ui": "npm --prefix tests/e2e run test:ui",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "release": "commit-and-tag-version",
    "release:dry": "commit-and-tag-version --dry-run",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.{js,jsx,json,md,yml,yaml}": []
  },
  "dependencies": {
    "@openrouter/ai-sdk-provider": "^2.10.0",
    "@openrouter/sdk": "^0.12.79",
    "@opentelemetry/api": "^1.9.1",
    "@supabase/supabase-js": "^2.108.0",
    "@vercel/otel": "^2.1.3",
    "ai": "^7.0.2",
    "bcryptjs": "^3.0.3",
    "next": "16.2.7",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.8",
    "commit-and-tag-version": "^12.7.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "promptfoo": "^0.121.17",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
